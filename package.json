{
  "name": "react-spa-comp",
  "version": "1.0.0",
  "description": "My react SPA component library",
  "homepage": "https://github.com/FalixRe/react-spa-comp#readme",
  "bugs": {
    "url": "https://github.com/FalixRe/react-spa-comp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FalixRe/react-spa-comp.git"
  },
  "license": "MIT",
  "author": "Wojciech Urban",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "type-check": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm run type-check",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "module",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
